def send_with_guardrails(query: str) -> tuple[str | None, dict]:
    """
    Full guardrail pipeline: input classifier -> generate -> output classifier.

    Returns:
        (response_or_none, metadata_dict)
        metadata_dict has keys: input_verdict, output_verdict
    """
    meta = {}

    input_class = llm_classify(query)
    meta['input_verdict'] = input_class

    if input_class != 'SAFE':
        show_verdict("Input classifier", input_class)
        return (None, meta)
    
    output = send_unguarded(query)

    output_class = llm_classify(query)
    meta['output_verdict'] = output_class

    if output_class != 'SAFE':
        show_verdict("Output classifier", output_class)
        return (None, meta)
    
    return (output, meta)

