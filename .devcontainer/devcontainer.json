// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "AISB 2026-04",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
	//
	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		// Enable Docker-outside-of-Docker to use the host's Docker daemon
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1.6.3": {}
	},
	//
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [
		7575
	],
	//
	// Load secrets from a gitignored .env file (copy from .env.example and fill in values)
	"runArgs": [
		"--env-file",
		"${localWorkspaceFolder}/.env",
		// Expose all host NVIDIA GPUs via nvidia-container-toolkit.
		// Requires nvidia-container-toolkit on the host (already set up on this machine).
		"--gpus=all"
	],
	//
	// Point pip cache and virtualenv to known locations
	"containerEnv": {
		"PIP_CACHE_DIR": "${containerWorkspaceFolder}/.package-cache/pip",
		"VIRTUAL_ENV": "/home/vscode/.venv"
	},
	// Activate the venv in the remote user session (terminals, extensions, tasks)
	// without interfering with Docker's container startup sequence
	"remoteEnv": {
		"PATH": "/home/vscode/.venv/bin:${containerEnv:PATH}"
	},
	//
	// Host Docker socket → container: initialize.sh writes .devcontainer/.run/docker-host.sock
	// (symlink to /var/run/docker.sock for root/group Docker, or rootless paths if that is missing).
	// That overrides docker-outside-of-docker's default bind when the default path does not exist. SSH keys.
	"mounts": [
		"source=${localWorkspaceFolder}/.devcontainer/.run/docker-host.sock,target=/var/run/docker-host.sock,type=bind",
		"source=${localWorkspaceFolder}/ssh,target=/mnt/ssh,type=bind"
	],
	//
	// Runs on the host before the container starts; creates directories and .env
	// required by the bind mounts and --env-file so Docker doesn't fail on fresh checkout.
	"initializeCommand": "bash .devcontainer/initialize.sh",
	//
	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "/bin/bash .devcontainer/setup-devcontainer.sh",
	//
	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter",
				"charliermarsh.ruff",
				"bierner.markdown-mermaid"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.codeActionsOnSave": {
					"source.fixAll": "explicit",
					"source.organizeImports": "never"
				},
				"ruff.lineLength": 120,
				"ruff.targetVersion": "py312",
				// Flag unused imports/variables but never auto-remove them on save.
				// F401 = unused import, F841 = unused local variable.
				"ruff.lint.unfixable": [
					"F401",
					"F841"
				],
				"[python]": {
					"editor.defaultFormatter": "charliermarsh.ruff"
				},
				"files.insertFinalNewline": true,
				"python.defaultInterpreterPath": "/home/vscode/.venv/bin/python",
				"python.envFile": "${workspaceFolder}/.env",
				"python.terminal.useEnvFile": true
			}
		}
	}
	//
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
